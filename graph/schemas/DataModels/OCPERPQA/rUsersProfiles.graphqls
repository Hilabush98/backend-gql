input inputUsersProfiles {
  user_id: ID!
  profile_id: ID!
  created_by: String
  is_active: Boolean
  modified_by: String
}
type UsersProfiles {
  group_id: ID!
  profile_id: ID!
  created_on: String
  created_by: String
  modified_on: String
  modified_by: String
  is_active: Boolean
}

extend type Query {
  getAllUsersProfiles: [UsersProfiles] @hasPermission(actions: ["R", "*"])
}
